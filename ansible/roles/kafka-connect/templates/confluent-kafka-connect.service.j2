[Unit]
Description=Confluent Kafka Connect
After=network.target confluent-kafka.service
Wants=confluent-kafka.service

[Service]
Type=simple
User={{ kafka_user }}
Group={{ kafka_group }}
EnvironmentFile={{ kafka_connect_env_file }}
ExecStart={{ kafka_connect_bin_dir }}/connect-distributed {{ kafka_connect_config_file }}
Restart=on-failure
RestartSec=10
LimitNOFILE={{ kafka_nofile_limit | default(100000) }}
TimeoutStopSec=180

[Install]
WantedBy=multi-user.target
