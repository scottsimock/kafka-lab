#!/bin/bash
export KAFKA_HEAP_OPTS="-Xmx{{ kafka_connect_heap_size }} -Xms{{ kafka_connect_heap_size }}"
export KAFKA_JVM_PERFORMANCE_OPTS="-server -XX:+UseG1GC -XX:MaxGCPauseMillis=20 -XX:InitiatingHeapOccupancyPercent=35 -XX:+ExplicitGCInvokesConcurrent -XX:MaxInlineLevel=15 -Djava.awt.headless=true"
export KAFKA_GC_LOG_OPTS="-Xlog:gc*:file=/var/log/kafka-connect/connect-gc.log:time,tags:filecount=10,filesize=100m"
