// Terraform Azure Backend Configuration (Shared Layer)
// Copy this file to backend.tfvars and fill in your values.
// Do NOT commit backend.tfvars to version control.

resource_group_name  = "klc-rg-kafkalab-scus"
storage_account_name = "klcstgtfstatescus"
container_name       = "tfstate"
key                  = "kafka-lab/dev-shared.tfstate"
use_oidc             = true
subscription_id      = "YOUR_SUBSCRIPTION_ID"
